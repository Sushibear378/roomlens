generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DesignStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model RoomUpload {
  id          String            @id @default(cuid())
  userId      String
  originalUrl String
  roomType    String
  style       String
  createdAt   DateTime          @default(now())
  designs     GeneratedDesign[]
}

model GeneratedDesign {
  id              String           @id @default(cuid())
  roomUploadId    String
  roomUpload      RoomUpload       @relation(fields: [roomUploadId], references: [id])
  generatedUrl    String?
  status          DesignStatus     @default(PROCESSING)
  replicateId     String?
  createdAt       DateTime         @default(now())
  matchedProducts MatchedProduct[]
}

model MatchedProduct {
  id                String          @id @default(cuid())
  generatedDesignId String
  generatedDesign   GeneratedDesign @relation(fields: [generatedDesignId], references: [id])
  name              String
  price             String
  imageUrl          String
  productUrl        String
  category          String
}
